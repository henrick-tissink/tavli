# Public site origin — used for canonical URLs, OG tags, sitemap, JSON-LD.
# In prod this should be the apex (e.g., https://tavli.ro).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Mapbox (consumer map view)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.placeholder_token_replace_with_real

# Google Maps Embed API key — used by <GoogleMapEmbed> on the detail page.
# Restrict the key by HTTP referrer (*.tavli.ro/*, localhost:*) and to the
# Maps Embed API only. Embed renders nothing if this is unset or placeholder.
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_KEY=your-google-maps-embed-key

# ─── Supabase (Phase 2) ──────────────────────────────────────────────────
# After `supabase start`, grab these from `supabase status`:
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# SERVICE-ROLE KEY — SERVER-ONLY. Never prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Drizzle / seed scripts connect directly:
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# ─── Resend (transactional email) ────────────────────────────────────────
RESEND_API_KEY=re_your_key_here
EMAIL_FROM="Tavli <hello@tavli.ro>"

# ─── Feature flags ───────────────────────────────────────────────────────
# Flip consumer data source from mock to Supabase.
USE_DB=false
# Onboarding approval: when true, new restaurants go to pending_review
# instead of live on publish.
ONBOARDING_REVIEW_REQUIRED=false
