# Public site origin — used for canonical URLs, OG tags, sitemap, JSON-LD.
# In prod this should be the apex (e.g., https://tavli.ro).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-side app origin — used by transactional email links (reservation
# confirmation, post-visit review). Must match the public origin in prod.
# Falls back to VERCEL_URL or localhost:3000 if unset.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Mapbox (consumer map view)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.placeholder_token_replace_with_real

# Google Maps Embed API key — used by <GoogleMapEmbed> on the detail page.
# Restrict the key by HTTP referrer (*.tavli.ro/*, localhost:*) and to the
# Maps Embed API only. Embed renders nothing if this is unset or placeholder.
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_KEY=your-google-maps-embed-key

# ─── Supabase (Phase 2) ──────────────────────────────────────────────────
# After `supabase start`, grab these from `supabase status`:
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# SERVICE-ROLE KEY — SERVER-ONLY. Never prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# AES-256-GCM key (32 bytes, base64) for the impersonation return cookie (§01 §5a.3 phase 2).
# Generate: openssl rand -base64 32
IMPERSONATION_COOKIE_SECRET=your_32_byte_base64_key_here

# Drizzle / seed scripts connect directly:
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# ─── Resend (transactional + marketing email) ────────────────────────────
RESEND_API_KEY=re_your_key_here
EMAIL_FROM="Tavli <hello@tavli.ro>"
# Marketing sender identity. Falls back to EMAIL_FROM, then the platform
# default, if unset. Per-venue display name / reply-to override this per send
# (restaurant_marketing_settings.email_sender_name / email_reply_to).
# MARKETING_FROM_EMAIL="Tavli <hello@tavli.ro>"
# Webhook signing secret (Resend dashboard → Webhooks). Required in prod for
# delivery / bounce / complaint tracking + bounce-suppression.
# RESEND_WEBHOOK_SECRET=whsec_xxxxxxxx

# ─── Cron jobs ───────────────────────────────────────────────────────────
# Hourly cron auth — set in Coolify "scheduled tasks" too.
CRON_SECRET=

# ─── Twilio (Wave 1 substrate; SMS in §04 / WhatsApp in §11) ─────────────
# Account SID + auth token from a Twilio project provisioned in the EU
# (Ireland) region for ANPC/GDPR per foundations §15a.8.
# Token is SERVER-ONLY — never NEXT_PUBLIC_.
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Platform fallback From identities (bare E.164 — the marketing sender adds the
# `whatsapp:` prefix itself, so do NOT prefix TWILIO_WHATSAPP_FROM). Per-venue
# senders override these: restaurant_marketing_settings.sms_sender_id and
# .whatsapp_sender_e164. Marketing SMS/WhatsApp FAIL LOUDLY if neither a venue
# nor a platform sender is set (no silent alphanumeric default — STOP replies
# must reach an inbound-capable number).
# Read by marketing sends (lib/marketing/send/production-senders.ts). The
# transactional SMS path uses TWILIO_FROM_NUMBER separately.
# TWILIO_SMS_FROM=+40123456789
# TWILIO_WHATSAPP_FROM=+40123456789

# ─── Stripe (Wave 1 substrate; full billing in §12 Wave 5) ───────────────
# Secret key — SERVER-ONLY (never NEXT_PUBLIC_). Use sk_test_* in dev,
# sk_live_* in prod. getStripe() throws on import without this.
# STRIPE_SECRET_KEY=sk_test_...

# Webhook signing secret. Created when you add the webhook endpoint in
# Stripe Dashboard; per-environment. Required for verifyStripeSignature.
# STRIPE_WEBHOOK_SECRET=whsec_...

# Optional publishable key for client-side Stripe Elements (lands with §12).
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─── pg-boss worker (Wave 1) ─────────────────────────────────────────────
# DIRECT Postgres URL — NOT the pgbouncer one used by DATABASE_URL.
# pg-boss relies on LISTEN/NOTIFY which pgbouncer (transaction mode)
# drops between transactions. In Supabase, copy the "Direct connection"
# string from the project's database settings.
# PGBOSS_DATABASE_URL=postgresql://postgres:[password]@db.<ref>.supabase.co:5432/postgres

# Flips scripts/worker.ts from "refuse to start" to "boot the worker
# loop". Set in Coolify on the worker service only; the web service
# leaves this unset so the same Docker image boots `next start`.
# WORKER_MODE=true

# ─── ANAF (Romanian VAT validation) ──────────────────────────────────────
# Base URL for ANAF's PlatitorTvaRest v8 API; used by corporate-bookings
# server actions to look up CUI (VAT) details when issuing invoices.
ANAF_API_BASE=https://webservicesp.anaf.ro/PlatitorTvaRest/api/v8/ws/tva

# ─── Observability (Wave 1) ──────────────────────────────────────────────
# OpenTelemetry service name. Defaults to "tavli-web" if unset.
# Override in the pg-boss worker process to "tavli-worker" so traces
# correctly attribute to the worker.
# OTEL_SERVICE_NAME=tavli-web

# Verbose Next.js spans (route handlers, RSC renders, etc.). Off by
# default; flip to "1" when debugging local trace propagation.
# NEXT_OTEL_VERBOSE=1

# Sentry — create the project in the EU region; the DSN encodes region
# routing so no separate knob is needed. When unset, Sentry init is a
# no-op (no events shipped, no errors).
# SENTRY_DSN=https://...@o123.ingest.de.sentry.io/456
# NEXT_PUBLIC_SENTRY_DSN=https://...@o123.ingest.de.sentry.io/456
# SENTRY_ENVIRONMENT=production
# NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1

# Source-map upload (build-time only); skip locally.
# SENTRY_ORG=tavli
# SENTRY_PROJECT=tavli-web
# SENTRY_AUTH_TOKEN=sntrys_...

# ─── Feature flags ───────────────────────────────────────────────────────
# Flip consumer data source from mock to Supabase.
USE_DB=false
# Onboarding approval: when true, new restaurants go to pending_review
# instead of live on publish.
ONBOARDING_REVIEW_REQUIRED=false

# ─── §12 Stripe prices (Wave 5) ──────────────────────────────────────────
# Populate AFTER running `npm run seed:stripe-prices` (needs STRIPE_SECRET_KEY).
# The seed script prints each price id to paste here. Then run
# `npm run verify:stripe-prices` to assert tax_behavior='exclusive' (§12 §3.6.3).
STRIPE_PRICE_BASE_MONTHLY=
STRIPE_PRICE_BASE_ANNUAL=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_PRICE_EXTRA_LOCATION_MONTHLY=
STRIPE_PRICE_EXTRA_LOCATION_ANNUAL=
STRIPE_PRICE_SMS_OVERAGE=
STRIPE_PRICE_WHATSAPP_OVERAGE=
